# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_NAME_TEST=taskflow_test
DB_USER=taskflow
DB_PASSWORD=taskflow

# Production
DATABASE_URL=postgres://user:password@host:5432/dbname

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=replace_with_random_64_char_string

# Email (Resend)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=onboarding@resend.dev

# Upstash Redis (cache)
UPSTASH_REDIS_URL=rediss://default:<password>@<host>:<port>

# CORS
CORS_ORIGIN=http://localhost:5173

# Cookie
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
