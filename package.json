{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow — multi-tenant task management SaaS. Capstone project for Engineering with Claude Code.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev:api": "nodemon src/app.js",
    "dev": "vite",
    "build": "vite build",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:e2e": "cross-env NODE_ENV=test_e2e playwright test",
    "migrate": "cross-env NODE_ENV=development knex migrate:latest",
    "migrate:test": "cross-env NODE_ENV=test knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "supertest": "^6.3.4",
    "vite": "^5.0.10"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.js"],
    "testPathIgnorePatterns": ["/node_modules/", "/e2e/"]
  }
}
