{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow — multi-tenant task management SaaS. Capstone project for Engineering with Claude Code.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev:api": "nodemon src/app.js",
    "dev": "vite",
    "build": "vite build",
    "test": "NODE_ENV=test jest --forceExit",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:e2e": "NODE_ENV=test_e2e playwright test",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "supertest": "^6.3.4",
    "vite": "^5.0.10"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathPattern": "src/.*\\.test\\.js$",
    "setupFilesAfterFramework": []
  }
}
